# Example backend environment variables. Do not commit real secrets.
# Copy this file to backend/.env and replace placeholders locally.

# Supabase project
PORT=4000
NODE_ENV=development
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
REDIS_URL=redis://localhost:6379
SCORE_WORKER_CONCURRENCY=3
FRONTEND_URL=http://localhost:3001
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Supabase Postgres development database
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password
DATABASE_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres

# If the direct host is IPv6-only in your environment, use the Supabase pooler string instead:
# DATABASE_URL=postgresql://postgres.your-project-ref:your-database-password@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require
